rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isPrimaryAdminEmail() {
      return isSignedIn() && request.auth.token.email == 'jcesperanza@neu.edu.ph';
    }

    function isAdminFromUsers() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }
    
    // Checks if the user's UID exists in the 'roles_admin' collection
    function isAdmin() {
      return isAdminFromUsers() || (isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
    }

    // --- Collection Rules ---

    // 0. Users: Primary source of truth for roles and status in current app model.
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();

      // Users can bootstrap their own profile. Only the known primary admin email can self-create as admin.
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.status == 'active'
        && (
          request.resource.data.role == 'professor'
          || (isPrimaryAdminEmail() && request.resource.data.role == 'admin')
        );

      // Users can update personal metadata but cannot elevate role/status. Admins can manage all fields.
      allow update: if isAdmin() || (
        isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
      );

      allow delete: if isAdmin();
    }

    // 1. Professors: Can read/write their own profile. Admins can manage all.
    match /professors/{professorId} {
      allow get: if isOwner(professorId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(professorId) && request.resource.data.id == professorId;
      allow update: if isExistingOwner(professorId) || isAdmin();
      allow delete: if isAdmin();
    }

    // 2. Lab Rooms: Publicly readable so everyone can see room names. Admin-only edits.
    match /lab_rooms/{roomId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // 3. Usage Logs: Professors can create their own logs. Admins can view/manage all.
    match /usage_logs/{usageLogId} {
      // Allow reading if you are an admin OR if you are the professor who owns the log
      allow get: if isAdmin() || (isSignedIn() && resource.data.professorId == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && resource.data.professorId == request.auth.uid);
      
      // Allow creation only for yourself
      allow create: if isSignedIn() && request.resource.data.professorId == request.auth.uid;
      
      // Allow updates (e.g., check-out) if you own the log or are an admin
      allow update: if isAdmin() || (resource != null && resource.data.professorId == request.auth.uid);
      
      allow delete: if isAdmin();
    }
    
    // 4. Admin Profiles
    match /admins/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isOwner(adminId) || isAdmin();
      allow delete: if isAdmin();
    }

    // 5. Admin Roles: The source of truth for admin permissions.
    match /roles_admin/{userId} {
      allow get: if isSignedIn();  // Anyone can check if a role exists (needed for isAdmin check)
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin(); // Only existing admins can add new admins
    }
  }
}